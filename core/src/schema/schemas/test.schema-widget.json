{
  "type": "object",
  "title": "A complex widget for testing schema extraction",
  "properties": {
    "title": {
      "type": "string",
      "default": ""
    },
    "count": {
      "type": "number",
      "default": 0
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "label": {
      "type": "string",
      "default": "default"
    },
    "size": {
      "type": "number",
      "default": 42
    },
    "visible": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "archived"
      ],
      "default": "draft"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium"
    },
    "trustLevel": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3,
        4
      ],
      "default": 2
    },
    "level": {
      "type": "number",
      "enum": [
        0,
        1,
        2
      ],
      "enumNames": [
        "Low",
        "Medium",
        "High"
      ],
      "default": 1
    },
    "rank": {
      "type": "number",
      "enum": [
        1,
        2,
        3
      ],
      "enumNames": [
        "First",
        "Second",
        "Third"
      ],
      "default": 1
    },
    "color": {
      "type": "string",
      "enum": [
        "red",
        "green",
        "blue"
      ],
      "default": "red"
    },
    "direction": {
      "type": "string",
      "enum": [
        "N",
        "S",
        "E",
        "W"
      ],
      "enumNames": [
        "North",
        "South",
        "East",
        "West"
      ],
      "default": "N"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": []
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "value"
        ]
      },
      "default": []
    },
    "description": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "data": {}
      },
      "required": [
        "key",
        "data"
      ]
    },
    "config": {
      "type": "object",
      "properties": {
        "color": {
          "type": "string"
        },
        "opacity": {
          "type": "number"
        },
        "nested": {
          "type": "object",
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          },
          "required": [
            "x",
            "y"
          ]
        }
      },
      "required": [
        "color",
        "opacity",
        "nested"
      ],
      "default": {
        "color": "blue",
        "opacity": 1,
        "nested": {
          "x": 0,
          "y": 0
        }
      }
    },
    "defaultArr": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "a",
        "b"
      ]
    },
    "defaultObj": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        }
      },
      "required": [
        "x"
      ],
      "default": {
        "x": 10
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "attrs": {
      "type": "object",
      "default": {}
    },
    "flag": {
      "type": "boolean",
      "default": true
    },
    "nickname": {
      "type": "string"
    },
    "value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ],
      "default": ""
    },
    "bigId": {
      "type": "integer",
      "default": 0
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "default": ""
    },
    "birthday": {
      "type": "string",
      "format": "date",
      "default": ""
    },
    "dueDate": {
      "type": "string",
      "format": "date-time"
    },
    "email": {
      "type": "string",
      "format": "email",
      "default": ""
    },
    "phone": {
      "type": "string",
      "title": "Contact phone number",
      "format": "tel",
      "default": ""
    },
    "displayName": {
      "type": "string",
      "title": "Display Name",
      "description": "The human-readable name shown in UI",
      "default": "Widget"
    },
    "linkedWidget": {
      "type": "string",
      "refType": "test.schema-widget"
    },
    "notes": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "targetPath": {
      "type": "string",
      "format": "path",
      "default": ""
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "format": "tags",
      "default": []
    },
    "accentColor": {
      "type": "string",
      "format": "color",
      "default": "#ff0000"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "default": ""
    },
    "apiKey": {
      "type": "string",
      "format": "password",
      "default": ""
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "actor": {
            "type": "string"
          },
          "ts": {
            "type": "number"
          }
        },
        "required": [
          "action",
          "actor",
          "ts"
        ]
      },
      "default": []
    }
  },
  "required": [
    "title",
    "count",
    "enabled",
    "label",
    "size",
    "visible",
    "status",
    "priority",
    "trustLevel",
    "level",
    "rank",
    "color",
    "direction",
    "tags",
    "scores",
    "items",
    "config",
    "defaultArr",
    "defaultObj",
    "history",
    "attrs",
    "flag",
    "value",
    "bigId",
    "createdAt",
    "birthday",
    "email",
    "phone",
    "displayName",
    "notes",
    "targetPath",
    "categories",
    "accentColor",
    "homepage",
    "apiKey",
    "changelog"
  ],
  "methods": {
    "increment": {
      "title": "Widget action — increment the counter.",
      "pre": [
        "count"
      ],
      "post": [
        "count"
      ],
      "arguments": []
    },
    "rename": {
      "title": "Set the title.",
      "arguments": [
        {
          "name": "newTitle",
          "type": "string"
        }
      ]
    },
    "addTag": {
      "title": "Add a tag with optional priority.",
      "description": "Appends tag to the list",
      "arguments": [
        {
          "name": "tag",
          "type": "string"
        },
        {
          "name": "prio",
          "type": "number"
        }
      ]
    },
    "configure": {
      "title": "Bulk update configuration",
      "arguments": [
        {
          "name": "opts",
          "type": "object",
          "properties": {
            "color": {
              "type": "string",
              "title": "CSS color value"
            },
            "opacity": {
              "type": "number",
              "title": "0-1 range"
            }
          }
        }
      ]
    },
    "watch": {
      "title": "Stream live updates.",
      "streaming": true,
      "arguments": [
        {
          "name": "filter",
          "type": "string"
        }
      ],
      "yields": {
        "type": "string"
      }
    },
    "reset": {
      "title": "Reset all counters to zero.",
      "pre": [
        "count",
        "scores"
      ],
      "post": [
        "count",
        "scores",
        "tags"
      ],
      "description": "Clears all accumulated data",
      "arguments": []
    },
    "archive": {
      "title": "Archive the widget.",
      "pre": [
        "status"
      ],
      "post": [
        "status"
      ],
      "arguments": []
    }
  },
  "$id": "test.schema-widget",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
