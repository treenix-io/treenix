{
  "type": "object",
  "title": "Mod catalog entry",
  "properties": {
    "name": {
      "type": "string",
      "default": ""
    },
    "state": {
      "type": "string",
      "enum": [
        "discovered",
        "loading",
        "loaded",
        "failed",
        "disabled"
      ],
      "default": "loaded"
    }
  },
  "required": [
    "name",
    "state"
  ],
  "$id": "t.mod",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
