{
  "$id": "autostart",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Service lifecycle manager — start/stop services via ref children",
  "properties": {},
  "methods": {
    "start": {
      "description": "Start a service at given path",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "title": "service to start"
            }
          },
          "required": [
            "path"
          ]
        }
      ]
    },
    "stop": {
      "description": "Stop a service at given path",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "required": [
            "path"
          ]
        }
      ]
    }
  }
}
