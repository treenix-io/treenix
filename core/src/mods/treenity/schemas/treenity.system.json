{
  "$id": "treenity.system",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "System actions — type discovery, view compilation, prefab deployment",
  "properties": {},
  "methods": {
    "catalog": {
      "description": "List all registered types with properties and actions",
      "arguments": [],
      "return": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "title": {
              "anyOf": [
                {},
                {
                  "type": "string"
                }
              ]
            },
            "properties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "actions": {}
          },
          "required": [
            "name",
            "properties",
            "actions"
          ]
        }
      }
    },
    "search_types": {
      "description": "Search types by keyword across names, properties, and actions",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "title": "Search keyword"
            }
          },
          "required": [
            "query"
          ]
        }
      ],
      "return": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "title": {
              "anyOf": [
                {},
                {
                  "type": "string"
                }
              ]
            },
            "properties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "actions": {}
          },
          "required": [
            "name",
            "properties",
            "actions"
          ]
        }
      }
    },
    "describe_type": {
      "description": "Full type schema with properties, actions, args, and cross-references",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "title": "Type name, e.g. \"cafe.contact\""
            }
          },
          "required": [
            "type"
          ]
        }
      ],
      "return": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "anyOf": [
              {},
              {
                "type": "string"
              }
            ]
          },
          "properties": {},
          "methods": {
            "anyOf": [
              {},
              {}
            ]
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "referencedBy": {}
        },
        "required": [
          "name",
          "properties",
          "references",
          "referencedBy"
        ]
      }
    },
    "compile_view": {
      "description": "Compile JSX view source. With source: compile + save to type node. Without: check existing",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "source": {
              "anyOf": [
                {},
                {
                  "type": "string"
                }
              ],
              "title": "JSX source code"
            },
            "path": {
              "anyOf": [
                {},
                {
                  "type": "string"
                }
              ],
              "title": "Type node path"
            }
          }
        }
      ],
      "return": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "ok": {}
            },
            "required": [
              "ok"
            ]
          },
          {
            "type": "object",
            "properties": {
              "ok": {},
              "error": {
                "type": "string"
              }
            },
            "required": [
              "ok",
              "error"
            ]
          },
          {
            "type": "object",
            "properties": {
              "ok": {
                "type": "boolean"
              },
              "saved": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "apply_template": {
      "description": "Apply template: copy children from template path to target path",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "templatePath": {
              "type": "string",
              "title": "Source template path, e.g. /templates/blog"
            },
            "targetPath": {
              "type": "string",
              "title": "Target path where template children will be copied"
            }
          },
          "required": [
            "templatePath",
            "targetPath"
          ]
        }
      ],
      "return": {
        "type": "object",
        "properties": {
          "applied": {
            "type": "string"
          },
          "blocks": {
            "type": "number"
          }
        },
        "required": [
          "applied",
          "blocks"
        ]
      }
    },
    "deploy_prefab": {
      "description": "Deploy module prefab template to target path. Idempotent",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "title": "Prefab source path, e.g. /sys/mods/cafe/prefabs/default"
            },
            "target": {
              "type": "string",
              "title": "Target path where nodes will be created"
            },
            "allowAbsolute": {
              "anyOf": [
                {},
                {},
                {}
              ],
              "title": "Allow writing outside target"
            }
          },
          "required": [
            "source",
            "target"
          ]
        }
      ],
      "return": {
        "type": "object",
        "properties": {
          "deployed": {
            "type": "number"
          },
          "skipped": {
            "type": "number"
          }
        },
        "required": [
          "deployed",
          "skipped"
        ]
      }
    }
  }
}
