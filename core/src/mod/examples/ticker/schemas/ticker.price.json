{
  "$id": "ticker.price",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Latest price snapshot — current price and timestamp",
  "properties": {
    "price": {
      "type": "number",
      "default": 0
    },
    "ts": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "price",
    "ts"
  ]
}
