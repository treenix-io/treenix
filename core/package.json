{
  "name": "@treenx/core",
  "version": "3.0.17",
  "description": "Composable typed tree engine — three primitives, everything else composes. Nodes, components, contexts.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "FSL-1.1-MIT",
  "author": "Treenix <hello@treenix.ai> (https://treenix.ai)",
  "homepage": "https://github.com/treenix-io/treenix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/treenix-io/treenix.git"
  },
  "keywords": [
    "treenix",
    "tree",
    "composable",
    "typed",
    "ecs",
    "node",
    "component",
    "context",
    "mcp",
    "ai-native"
  ],
  "imports": {
    "#*": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "treenix": {
    "clients": "./src/mods/clients.ts",
    "servers": "./src/mods/servers.ts"
  },
  "bin": {
    "fix-hash-imports": "./bin/fix-hash-imports.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/*.test.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && fix-hash-imports",
    "prepack": "npm run build",
    "test": "tsx --conditions development --test src/**/*.test.ts",
    "dev:server": "tsx --conditions development --watch src/server/main.ts ../root.json",
    "schema": "tsx src/schema/extract-schemas-oxc.ts src ../mods ../packages ../../mods"
  },
  "dependencies": {
    "@trpc/client": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "dotenv": "^17.4.2",
    "fast-json-patch": "^3.1.1",
    "grammy": "^1.42.0",
    "immer": "^11.1.4",
    "oxc-parser": "^0.128.0",
    "quickjs-emscripten": "^0.32.0",
    "sift": "^17.1.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@orama/orama": "^3.1.18"
  },
  "peerDependencies": {
    "tsx": "^4.21.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
