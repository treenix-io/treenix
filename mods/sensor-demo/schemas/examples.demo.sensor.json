{
  "$id": "examples.demo.sensor",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Fake sensor that generates readings around a base value",
  "properties": {
    "baseValue": {
      "type": "number",
      "default": 20
    }
  },
  "required": [
    "baseValue"
  ],
  "methods": {
    "setBase": {
      "description": "Set the base value around which readings oscillate",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "value": {
              "type": "number",
              "title": "Base temperature"
            }
          },
          "required": [
            "value"
          ]
        }
      ]
    }
  }
}
