{
  "$id": "whisper.audio",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Audio file metadata — filename, size, MIME type",
  "properties": {
    "filename": {
      "type": "string",
      "default": ""
    },
    "size": {
      "type": "number",
      "default": 0
    },
    "mime": {
      "type": "string",
      "default": "audio/wav"
    }
  },
  "required": [
    "filename",
    "size",
    "mime"
  ]
}
