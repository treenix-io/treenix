{
  "$id": "brahman.page",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Bot conversation page — command trigger and ordered action sequence",
  "properties": {
    "command": {
      "type": "string",
      "title": "Command",
      "description": "Telegram command, e.g. /start",
      "default": ""
    },
    "positions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Ordered child action paths",
      "default": []
    }
  },
  "required": [
    "command",
    "positions"
  ]
}
