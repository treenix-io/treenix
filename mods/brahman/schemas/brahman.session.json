{
  "$id": "brahman.session",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "User conversation state — session data, history, pending callbacks",
  "properties": {
    "tid": {
      "type": "number",
      "default": 0
    },
    "data": {},
    "history": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "callbacks": {
      "title": "Pending callbacks",
      "description": "messageType → action path"
    }
  },
  "required": [
    "tid",
    "data",
    "history",
    "callbacks"
  ]
}
