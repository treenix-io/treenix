{
  "type": "object",
  "title": "User conversation state — session data, history, pending callbacks",
  "properties": {
    "tid": {
      "type": "number",
      "default": 0
    },
    "data": {
      "type": "object",
      "default": {}
    },
    "history": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "callbacks": {
      "type": "object",
      "title": "Pending callbacks",
      "description": "messageType → action path",
      "default": {}
    }
  },
  "required": [
    "tid",
    "data",
    "history",
    "callbacks"
  ],
  "$id": "brahman.session",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
