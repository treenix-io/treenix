{
  "$id": "brahman.action.message",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Send message — text with optional menu and link previews",
  "properties": {
    "text": {
      "title": "Text",
      "format": "tstring",
      "default": {}
    },
    "disableLinks": {
      "type": "boolean",
      "title": "Disable link previews",
      "default": false
    },
    "menuType": {
      "type": "string",
      "enum": [
        "force_reply",
        "inline",
        "inline_close",
        "inline_new",
        "keyboard",
        "none",
        "remove"
      ],
      "title": "Menu type",
      "default": "none"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "buttons": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "title": {},
                "url": {
                  "anyOf": [
                    {},
                    {
                      "type": "string"
                    }
                  ]
                },
                "tags": {
                  "anyOf": [
                    {},
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                },
                "action": {
                  "anyOf": [
                    {},
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "target": {
                          "anyOf": [
                            {},
                            {
                              "type": "string"
                            }
                          ]
                        }
                      },
                      "required": [
                        "type"
                      ]
                    }
                  ]
                }
              },
              "required": [
                "id",
                "title"
              ]
            }
          }
        },
        "required": [
          "buttons"
        ]
      },
      "title": "Menu rows",
      "default": []
    },
    "chatId": {
      "type": "string",
      "title": "Send to chat ID",
      "description": "Leave empty for current chat",
      "default": ""
    },
    "replyToMsgId": {
      "type": "string",
      "title": "Reply to message ID",
      "description": "Session field with message ID",
      "default": ""
    }
  },
  "required": [
    "text",
    "disableLinks",
    "menuType",
    "rows",
    "chatId",
    "replyToMsgId"
  ],
  "methods": {
    "run": {
      "arguments": []
    }
  }
}
