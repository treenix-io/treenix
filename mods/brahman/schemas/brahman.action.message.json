{
  "$id": "brahman.action.message",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Send message — text with optional menu and link previews",
  "properties": {
    "text": {
      "type": "object",
      "title": "Text",
      "format": "tstring",
      "default": {}
    },
    "disableLinks": {
      "type": "boolean",
      "title": "Disable link previews",
      "default": false
    },
    "menuType": {
      "type": "string",
      "enum": [
        "none",
        "inline",
        "inline_new",
        "inline_close",
        "keyboard",
        "remove",
        "force_reply"
      ],
      "title": "Menu type",
      "default": "none"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "buttons": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "title": {
                  "type": "object"
                },
                "url": {
                  "type": "string"
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "action": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "target": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type"
                  ]
                }
              },
              "required": [
                "id",
                "title"
              ]
            }
          }
        },
        "required": [
          "buttons"
        ]
      },
      "title": "Menu rows",
      "default": []
    },
    "chatId": {
      "type": "string",
      "title": "Send to chat ID",
      "description": "Leave empty for current chat",
      "default": ""
    },
    "replyToMsgId": {
      "type": "string",
      "title": "Reply to message ID",
      "description": "Session field with message ID",
      "default": ""
    }
  },
  "required": [
    "text",
    "disableLinks",
    "menuType",
    "rows",
    "chatId",
    "replyToMsgId"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  }
}
