{
  "$id": "brahman.action.call",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Call tree action — execute any Treenity action from bot flow",
  "properties": {
    "path": {
      "type": "string",
      "title": "Node path",
      "description": "Template with {session.vars}",
      "default": ""
    },
    "action": {
      "type": "string",
      "title": "Action name",
      "default": ""
    },
    "type": {
      "type": "string",
      "title": "Component type",
      "description": "Optional $type for resolution",
      "default": ""
    },
    "key": {
      "type": "string",
      "title": "Component key",
      "description": "Optional named component key",
      "default": ""
    },
    "dataExpr": {
      "type": "string",
      "title": "Input data",
      "format": "textarea",
      "description": "JSON template",
      "default": "{}"
    },
    "saveTo": {
      "type": "string",
      "title": "Save result to",
      "description": "Session key for result",
      "default": ""
    }
  },
  "required": [
    "path",
    "action",
    "type",
    "key",
    "dataExpr",
    "saveTo"
  ],
  "methods": {
    "run": {
      "arguments": []
    }
  }
}
