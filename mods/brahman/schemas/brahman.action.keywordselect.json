{
  "type": "object",
  "properties": {
    "textFrom": {
      "type": "string",
      "title": "Source text",
      "description": "Template for text to analyze",
      "default": ""
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "keywords",
          "message"
        ]
      },
      "title": "Keyword entries",
      "description": "Array of {keywords, message} pairs",
      "default": []
    }
  },
  "required": [
    "textFrom",
    "elements"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  },
  "$id": "brahman.action.keywordselect",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
