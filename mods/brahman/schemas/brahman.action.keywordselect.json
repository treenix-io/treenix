{
  "$id": "brahman.action.keywordselect",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Keyword matcher — select response based on text keywords",
  "properties": {
    "textFrom": {
      "type": "string",
      "title": "Source text",
      "description": "Template for text to analyze",
      "default": ""
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "keywords",
          "message"
        ]
      },
      "title": "Keyword entries",
      "description": "Array of {keywords, message} pairs"
    }
  },
  "required": [
    "textFrom",
    "elements"
  ],
  "methods": {
    "run": {
      "arguments": []
    }
  }
}
