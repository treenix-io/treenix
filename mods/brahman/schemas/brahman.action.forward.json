{
  "type": "object",
  "properties": {
    "msgIdFrom": {
      "type": "string",
      "title": "Message ID from @description Session field with msg id. Empty = current msg",
      "default": ""
    },
    "toFrom": {
      "type": "string",
      "title": "Forward to @description Chat/user ID template",
      "default": ""
    }
  },
  "required": [
    "msgIdFrom",
    "toFrom"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  },
  "$id": "brahman.action.forward",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
