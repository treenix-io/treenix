{
  "$id": "brahman.action.forward",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Forward message — relay message to another chat",
  "properties": {
    "msgIdFrom": {
      "type": "string",
      "title": "Message ID from",
      "description": "Session field with msg id. Empty = current msg",
      "default": ""
    },
    "toFrom": {
      "type": "string",
      "title": "Forward to",
      "description": "Chat/user ID template",
      "default": ""
    }
  },
  "required": [
    "msgIdFrom",
    "toFrom"
  ],
  "methods": {
    "run": {
      "arguments": []
    }
  }
}
