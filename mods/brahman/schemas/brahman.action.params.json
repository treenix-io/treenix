{
  "$id": "brahman.action.params",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Parse parameters — split and name input parts",
  "properties": {
    "base64": {
      "type": "boolean",
      "title": "Base64 decode",
      "default": false
    },
    "split": {
      "type": "string",
      "title": "Split delimiter",
      "default": ","
    },
    "names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Parameter names",
      "format": "tags",
      "default": []
    }
  },
  "required": [
    "base64",
    "split",
    "names"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  }
}
