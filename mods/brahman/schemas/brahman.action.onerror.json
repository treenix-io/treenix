{
  "type": "object",
  "properties": {
    "error": {
      "type": "string",
      "title": "Error text",
      "description": "Substring to match in error message",
      "default": ""
    },
    "action": {
      "type": "string",
      "title": "Action path",
      "description": "Path to action node to run",
      "default": ""
    }
  },
  "required": [
    "error",
    "action"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  },
  "$id": "brahman.action.onerror",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
