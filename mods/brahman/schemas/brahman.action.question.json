{
  "type": "object",
  "properties": {
    "text": {
      "type": "object",
      "title": "Prompt text @format tstring",
      "default": {}
    },
    "inputType": {
      "type": "string",
      "enum": [
        "text",
        "photo"
      ],
      "title": "Input type",
      "default": "text"
    },
    "saveTo": {
      "type": "string",
      "title": "Save answer to",
      "default": ""
    },
    "deleteMessages": {
      "type": "boolean",
      "title": "Delete messages @description Delete question and answer after receiving",
      "default": false
    }
  },
  "required": [
    "text",
    "inputType",
    "saveTo",
    "deleteMessages"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  },
  "$id": "brahman.action.question",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
