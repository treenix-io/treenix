{
  "type": "object",
  "properties": {
    "condition": {
      "type": "string",
      "title": "Condition",
      "format": "textarea",
      "description": "JS expression evaluated at runtime",
      "default": ""
    },
    "actionIf": {
      "type": "string",
      "title": "Action if true",
      "description": "Path to action node",
      "default": ""
    },
    "actionElse": {
      "type": "string",
      "title": "Action if false",
      "default": ""
    },
    "stopAfterAction": {
      "type": "boolean",
      "title": "Stop after action",
      "default": false
    }
  },
  "required": [
    "condition",
    "actionIf",
    "actionElse",
    "stopAfterAction"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  },
  "$id": "brahman.action.ifelse",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
