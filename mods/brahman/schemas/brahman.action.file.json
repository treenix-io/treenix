{
  "$id": "brahman.action.file",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Send file — deliver photo/document/video/audio to chat",
  "properties": {
    "fileId": {
      "type": "string",
      "title": "File node path",
      "default": ""
    },
    "asType": {
      "type": "string",
      "title": "Override type",
      "description": "photo, document, video, audio, voice",
      "default": ""
    }
  },
  "required": [
    "fileId",
    "asType"
  ],
  "methods": {
    "run": {
      "arguments": [
        {
          "name": "bCtx",
          "type": "object",
          "properties": {
            "ctx": {},
            "tree": {},
            "session": {
              "type": "object"
            },
            "sessionNode": {},
            "user": {},
            "lang": {
              "type": "string"
            },
            "botPath": {
              "type": "string"
            },
            "userTags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "botLangs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error": {}
          },
          "required": [
            "ctx",
            "tree",
            "session",
            "sessionNode",
            "user",
            "lang",
            "botPath",
            "userTags",
            "botLangs"
          ]
        }
      ]
    }
  }
}
