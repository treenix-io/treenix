{
  "$id": "brahman.action.file",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Send file — deliver photo/document/video/audio to chat",
  "properties": {
    "fileId": {
      "type": "string",
      "title": "File node path",
      "default": ""
    },
    "asType": {
      "type": "string",
      "title": "Override type",
      "description": "photo, document, video, audio, voice",
      "default": ""
    }
  },
  "required": [
    "fileId",
    "asType"
  ],
  "methods": {
    "run": {
      "arguments": []
    }
  }
}
