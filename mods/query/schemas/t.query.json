{
  "$id": "t.query",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Tree-backed virtual view configuration for filtering and grouping child nodes.",
  "properties": {
    "source": {
      "type": "string",
      "title": "Source path",
      "default": "/"
    },
    "typeFilter": {
      "type": "string",
      "title": "Type filter",
      "default": ""
    },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "required": [
          "field",
          "value"
        ]
      },
      "title": "Filters",
      "format": "hidden",
      "default": []
    },
    "mode": {
      "type": "string",
      "enum": [
        "list",
        "table",
        "kanban"
      ],
      "title": "Render mode",
      "default": "list"
    },
    "groupBy": {
      "type": "string",
      "title": "Group by field",
      "default": "status"
    }
  },
  "required": [
    "source",
    "typeFilter",
    "filters",
    "mode",
    "groupBy"
  ]
}
