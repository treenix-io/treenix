{
  "type": "object",
  "title": "Local MCP server binding used by agent clients and external tools.",
  "properties": {
    "port": {
      "type": "number",
      "default": 3212
    },
    "host": {
      "type": "string",
      "title": "Bind host",
      "default": "127.0.0.1"
    }
  },
  "required": [
    "port",
    "host"
  ],
  "$id": "mcp.server",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
