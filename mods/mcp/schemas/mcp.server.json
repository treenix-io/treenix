{
  "$id": "mcp.server",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "port": {
      "type": "number",
      "default": 3212
    },
    "host": {
      "type": "string",
      "title": "Bind host",
      "default": "127.0.0.1"
    }
  },
  "required": [
    "port",
    "host"
  ]
}
