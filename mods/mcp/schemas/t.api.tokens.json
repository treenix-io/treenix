{
  "type": "object",
  "title": "Server-side registry for creating and revoking machine credentials.",
  "properties": {},
  "methods": {
    "create": {
      "mutation": "Create API token for an agent",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ]
        }
      ]
    },
    "revoke": {
      "mutation": "Revoke an API token by name",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ]
        }
      ]
    }
  },
  "$id": "t.api.tokens",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
