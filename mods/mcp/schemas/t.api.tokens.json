{
  "$id": "t.api.tokens",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "API token manager for creating and revoking machine access credentials.",
  "properties": {},
  "methods": {
    "create": {
      "kind": "write",
      "arguments": [
        {
          "name": "_data",
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "groups": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "name"
          ]
        }
      ]
    },
    "revoke": {
      "kind": "write",
      "arguments": [
        {
          "name": "_data",
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ]
        }
      ]
    }
  }
}
