{
  "$id": "simple.time-track",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start": {
            "type": "number"
          },
          "end": {
            "type": "number"
          }
        },
        "required": [
          "start",
          "end"
        ]
      },
      "default": []
    },
    "running": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "entries",
    "running"
  ],
  "methods": {
    "start": {
      "description": "Start the timer",
      "arguments": []
    },
    "stop": {
      "description": "Stop the timer",
      "arguments": []
    }
  }
}
