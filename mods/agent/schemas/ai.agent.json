{
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "title": "Open-ended role string. Guardian policies keyed by role.",
      "default": "qa"
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "working",
        "blocked",
        "error",
        "offline"
      ],
      "default": "offline"
    },
    "trustLevel": {
      "anyOf": [
        {
          "type": "number",
          "enum": [
            0
          ]
        },
        {
          "type": "number",
          "enum": [
            1
          ]
        },
        {
          "type": "number",
          "enum": [
            2
          ]
        },
        {
          "type": "number",
          "enum": [
            3
          ]
        },
        {
          "type": "number",
          "enum": [
            4
          ]
        }
      ],
      "title": "Trust level: 0=sandbox 1=observer 2=worker 3=operator 4=admin",
      "default": 2
    },
    "model": {
      "type": "string",
      "default": "claude-opus-4-6"
    },
    "systemPrompt": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "currentTask": {
      "type": "string",
      "title": "Path to current board.task being worked on",
      "default": ""
    },
    "currentRun": {
      "type": "string",
      "title": "Path to current ai.run (live log)",
      "default": ""
    },
    "lastRunAt": {
      "type": "number",
      "default": 0
    },
    "totalTokens": {
      "type": "number",
      "title": "Total tokens used across all tasks",
      "default": 0
    }
  },
  "required": [
    "role",
    "status",
    "trustLevel",
    "model",
    "systemPrompt",
    "currentTask",
    "currentRun",
    "lastRunAt",
    "totalTokens"
  ],
  "methods": {
    "online": {
      "description": "Bring agent online",
      "arguments": []
    },
    "offline": {
      "description": "Take agent offline",
      "arguments": []
    },
    "assign": {
      "description": "Assign a board task to this agent",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "task": {
              "type": "string",
              "title": "Path to board.task"
            }
          },
          "required": [
            "task"
          ]
        }
      ]
    },
    "complete": {
      "description": "Agent finished current task",
      "arguments": []
    },
    "block": {
      "description": "Agent is blocked",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "reason": {
              "type": "string",
              "title": "Reason"
            }
          }
        }
      ]
    },
    "fail": {
      "description": "Agent hit an error",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "title": "Error message"
            }
          }
        }
      ]
    }
  },
  "$id": "ai.agent",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
