{
  "$id": "ai.pool",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Concurrency pool — lives on /agents node",
  "properties": {
    "maxConcurrent": {
      "type": "number",
      "default": 2
    },
    "active": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Paths of currently active agent nodes",
      "default": []
    },
    "queue": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Paths of agents waiting for a slot",
      "default": []
    }
  },
  "required": [
    "maxConcurrent",
    "active",
    "queue"
  ],
  "methods": {
    "scan": {
      "arguments": []
    }
  }
}
