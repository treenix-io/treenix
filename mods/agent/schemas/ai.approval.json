{
  "type": "object",
  "title": "Human decision record for an agent tool call that requires approval.",
  "properties": {
    "agentPath": {
      "type": "string",
      "default": ""
    },
    "agentRole": {
      "type": "string",
      "default": ""
    },
    "tool": {
      "type": "string",
      "default": ""
    },
    "input": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "inputTruncated": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "denied"
      ],
      "default": "pending"
    },
    "reason": {
      "type": "string",
      "default": ""
    },
    "createdAt": {
      "type": "number",
      "default": 0
    },
    "resolvedAt": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "agentPath",
    "agentRole",
    "tool",
    "input",
    "inputTruncated",
    "status",
    "reason",
    "createdAt",
    "resolvedAt"
  ],
  "methods": {
    "approve": {
      "description": "Approve this tool usage",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "remember": {
              "type": "string",
              "enum": [
                "agent",
                "global"
              ],
              "title": "Remember this decision for future calls"
            }
          }
        }
      ]
    },
    "deny": {
      "description": "Deny this tool usage",
      "arguments": [
        {
          "name": "data",
          "type": "object",
          "properties": {
            "remember": {
              "type": "string",
              "enum": [
                "agent",
                "global"
              ],
              "title": "Remember this decision for future calls"
            }
          }
        }
      ]
    }
  },
  "$id": "ai.approval",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
