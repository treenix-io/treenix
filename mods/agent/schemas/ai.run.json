{
  "type": "object",
  "properties": {
    "taskRef": {
      "type": "string",
      "title": "Reference to board task",
      "default": ""
    },
    "prompt": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "result": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "mode": {
      "type": "string",
      "enum": [
        "plan",
        "work",
        "discuss",
        "chat"
      ],
      "default": "work"
    }
  },
  "required": [
    "taskRef",
    "prompt",
    "result",
    "mode"
  ],
  "methods": {
    "stop": {
      "description": "Stop the running task",
      "arguments": []
    }
  },
  "$id": "ai.run",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
