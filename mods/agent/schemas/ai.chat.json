{
  "$id": "ai.chat",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Interactive chat session — compose with ai.thread for messages",
  "properties": {
    "streaming": {
      "type": "boolean",
      "default": false
    },
    "sessionId": {
      "type": "string",
      "default": ""
    }
  },
  "required": [
    "streaming",
    "sessionId"
  ],
  "methods": {
    "clear": {
      "description": "Clear chat history and reset session",
      "arguments": []
    },
    "send": {
      "arguments": [
        {
          "name": "data"
        }
      ]
    },
    "stop": {
      "arguments": []
    }
  }
}
