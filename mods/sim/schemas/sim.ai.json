{
  "$id": "sim.ai",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Agent AI config — system prompt and model override",
  "properties": {
    "systemPrompt": {
      "type": "string",
      "format": "textarea",
      "default": ""
    },
    "model": {
      "anyOf": [
        {},
        {
          "type": "string"
        }
      ]
    }
  },
  "required": [
    "systemPrompt"
  ]
}
