{
  "type": "object",
  "title": "Rich document — Tiptap JSON with embedded Treenity components",
  "properties": {
    "title": {
      "type": "string",
      "title": "Title",
      "default": "Untitled"
    },
    "content": {
      "type": "string",
      "title": "Content",
      "default": "{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\",\"content\":[{\"type\":\"text\",\"text\":\"Нажмите кнопку Edit чтобы начать редактирование.\"}]}]}"
    }
  },
  "required": [
    "title",
    "content"
  ],
  "$id": "doc.page",
  "$schema": "http://json-schema.org/draft-07/schema#"
}
