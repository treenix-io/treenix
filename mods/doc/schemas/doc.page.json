{
  "$id": "doc.page",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Rich document — Tiptap JSON with embedded Treenix components",
  "properties": {
    "title": {
      "type": "string",
      "title": "Title",
      "default": "Untitled"
    },
    "content": {
      "type": "object",
      "title": "Content",
      "default": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Press Edit to start editing."
              }
            ]
          }
        ]
      }
    }
  },
  "required": [
    "title",
    "content"
  ]
}
