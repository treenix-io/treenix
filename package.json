{
  "private": true,
  "type": "module",
  "workspaces": [
    "core",
    "packages/*",
    "mods/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/treenity-ai/treenity.git"
  },
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:e2e": "playwright test",
    "dev:server": "npm run dev:server -w @treenity/core",
    "dev:front": "npm run dev -w @treenity/react",
    "schema": "npm run schema -w @treenity/core",
    "typecheck": "tsc -p core --noEmit && tsc -p packages/react --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "onnxruntime-node": "1.24.2"
  },
  "dependencies": {
    "d3-hierarchy": "^3.1.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0"
  }
}
