{
  "name": "@treenity/react",
  "version": "3.0.10",
  "description": "React binding for Treenity — reactive hooks, admin UI, and context-based component rendering.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "FSL-1.1-MIT",
  "author": "Treenity <hello@treenity.ai> (https://treenity.ai)",
  "homepage": "https://github.com/treenity-ai/treenity",
  "repository": {
    "type": "git",
    "url": "https://github.com/treenity-ai/treenity.git",
    "directory": "packages/react"
  },
  "keywords": [
    "treenity",
    "react",
    "hooks",
    "reactive",
    "tree",
    "composable",
    "admin",
    "ui",
    "mcp",
    "ai-native"
  ],
  "imports": {
    "#*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui/*": {
      "development": [
        "./src/components/ui/*.ts",
        "./src/components/ui/*.tsx"
      ],
      "types": "./dist/components/ui/*.d.ts",
      "default": "./dist/components/ui/*.js"
    },
    "./*.css": "./src/*.css",
    "./*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "treenity": {
    "clients": "./src/mods/clients.ts",
    "servers": "./src/mods/servers.ts"
  },
  "files": [
    "dist",
    "src",
    "vite-plugin-treenity.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && fix-hash-imports --copy-assets",
    "prepack": "npm run build",
    "test": "tsx --conditions development --experimental-test-module-mocks --import ./test/register-dom.mjs --import ./test/register-css.mjs --test src/**/*.test.ts",
    "dev": "vite"
  },
  "peerDependencies": {
    "@treenity/core": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.19",
    "fast-json-patch": "^3.1.1",
    "immer": "^11.1.4",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4.7.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "valtio": "^2.1.2",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.8.9",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
