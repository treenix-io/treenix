{
  "name": "@treenx/react",
  "version": "3.0.17",
  "description": "React binding for Treenix — reactive hooks, admin UI, and context-based component rendering.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "FSL-1.1-MIT",
  "author": "Treenix <hello@treenix.ai> (https://treenix.ai)",
  "homepage": "https://github.com/treenix-io/treenix",
  "repository": {
    "type": "git",
    "url": "https://github.com/treenix-io/treenix.git",
    "directory": "packages/react"
  },
  "keywords": [
    "treenix",
    "react",
    "hooks",
    "reactive",
    "tree",
    "composable",
    "admin",
    "ui",
    "mcp",
    "ai-native"
  ],
  "imports": {
    "#*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui/*": {
      "development": [
        "./src/components/ui/*.ts",
        "./src/components/ui/*.tsx"
      ],
      "types": "./dist/components/ui/*.d.ts",
      "default": "./dist/components/ui/*.js"
    },
    "./*.css": "./src/*.css",
    "./*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "treenix": {
    "clients": "./src/mods/clients.ts",
    "servers": "./src/mods/servers.ts"
  },
  "files": [
    "dist",
    "src",
    "vite-plugin-treenix.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && fix-hash-imports --copy-assets",
    "build:spa": "NODE_OPTIONS='--import tsx --conditions=development' vite build --outDir dist-spa --emptyOutDir",
    "build:ssr": "NODE_OPTIONS='--import tsx --conditions=development' vite build --ssr src/ssr/entry-server.ts --outDir ../ssr/dist-ssr --emptyOutDir",
    "build:front": "npm run build:spa && npm run build:ssr",
    "prepack": "npm run build",
    "test": "tsx --conditions development --experimental-test-module-mocks --import ./test/register-dom.mjs --import ./test/register-css.mjs --test src/**/*.test.ts",
    "dev": "NODE_OPTIONS=\"$NODE_OPTIONS --import tsx --conditions=development\" vite"
  },
  "peerDependencies": {
    "@treenx/core": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "fast-json-patch": "^3.1.1",
    "immer": "^11.1.4",
    "lucide-react": "^1.12.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-resizable-panels": "^4.10.0",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "valtio": "^2.3.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.3.2",
    "@treenx/ssr": "^0.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
