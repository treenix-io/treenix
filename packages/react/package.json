{
  "name": "@treenity/react",
  "version": "3.0.9",
  "description": "React binding for Treenity — reactive hooks, admin UI, and context-based component rendering.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "FSL-1.1-MIT",
  "author": "Treenity <hello@treenity.ai> (https://treenity.ai)",
  "homepage": "https://github.com/treenity-ai/treenity",
  "repository": {
    "type": "git",
    "url": "https://github.com/treenity-ai/treenity.git",
    "directory": "packages/react"
  },
  "keywords": [
    "treenity",
    "react",
    "hooks",
    "reactive",
    "tree",
    "composable",
    "admin",
    "ui",
    "mcp",
    "ai-native"
  ],
  "imports": {
    "#*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui/*": {
      "development": [
        "./src/components/ui/*.ts",
        "./src/components/ui/*.tsx"
      ],
      "types": "./dist/components/ui/*.d.ts",
      "default": "./dist/components/ui/*.js"
    },
    "./*.css": "./src/*.css",
    "./*": {
      "development": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "treenity": {
    "clients": "./mods/clients.ts",
    "servers": "./mods/servers.ts"
  },
  "files": [
    "dist",
    "src",
    "vite-plugin-treenity.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && fix-hash-imports --copy-assets",
    "prepack": "npm run build",
    "test": "tsx --conditions development --test src/**/*.test.ts",
    "dev": "vite"
  },
  "peerDependencies": {
    "@treenity/core": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@flowgram.ai/free-layout-editor": "^1.0.7",
    "@tanstack/react-query": "^5.90.21",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "@treenity/react": "^3.0.3",
    "@trpc/client": "^11.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-hierarchy": "^3.1.2",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dayjs": "^1.11.19",
    "embla-carousel-react": "^8.6.0",
    "fast-json-patch": "^3.1.1",
    "immer": "^11.1.4",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.34.3",
    "next-themes": "^0.4.6",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-react": "^0.5.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react-easy-crop": "^5.5.6",
    "react-grid-layout": "^2.2.2",
    "react-resizable-panels": "^4.7.2",
    "sonner": "^2.0.7",
    "swiper": "^12.1.2",
    "tailwind-merge": "^3.4.0",
    "valtio": "^2.1.2",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.183.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
