import 'dotenv/config'
import { treenity } from '@treenity/core/server/factory'
import { type NodeData } from '@treenity/core'
import { readFile } from 'node:fs/promises'
import { resolve } from 'node:path'

const rootPath = resolve(process.argv[2] || 'root.json')
const rootNode = JSON.parse(await readFile(rootPath, 'utf-8')) as NodeData

const modsDir = new URL('./mods', import.meta.url).pathname

const app = await treenity({
  rootNode,
  modsDir,
})

await app.listen(Number(process.env.PORT) || 3211, {
  allowedOrigins: ['http://localhost:3210'],
})
