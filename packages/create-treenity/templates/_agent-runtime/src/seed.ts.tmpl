import type { Tree } from '@treenity/core/tree'

export async function seed(store: Tree) {
  // Skip if already seeded
  if (await store.get('/agents')) return

  // Agent pool — orchestrator service runs here
  await store.set({ $path: '/agents', $type: 'ai.pool', maxConcurrent: 2, active: [], queue: [] })

  // Guardian — global policy (read-only by default, writes require approval)
  await store.set({
    $path: '/agents/guardian', $type: 'dir',
    policy: {
      $type: 'ai.policy',
      allow: [
        'mcp__treenity__get_node', 'mcp__treenity__list_children',
        'mcp__treenity__catalog', 'mcp__treenity__describe_type',
        'mcp__treenity__search_types', 'mcp__treenity__compile_view',
      ],
      deny: [
        'mcp__treenity__remove_node',
        'Bash:git checkout *', 'Bash:git checkout -- *',
        'Bash:git reset --hard*', 'Bash:git push --force*', 'Bash:git clean*',
        'Bash:rm -rf *', 'Bash:rm -r *', 'Bash:cat *.env*',
      ],
      escalate: [
        'mcp__treenity__set_node', 'mcp__treenity__execute', 'mcp__treenity__deploy_prefab',
        'Bash:git add *', 'Bash:git commit *', 'Bash:git push *',
        'Bash:sed *', 'Bash:mv *', 'Bash:cp *',
      ],
    },
  })

  // Approvals queue
  await store.set({ $path: '/agents/approvals', $type: 'ai.approvals' })

  // QA agent — runs tests, checks quality
  await store.set({
    $path: '/agents/qa', $type: 'ai.agent',
    role: 'qa', status: 'idle', currentTask: '', taskRef: '',
    lastRunAt: 0, totalTokens: 0,
    config: {
      $type: 'metatron.config',
      model: 'claude-sonnet-4-6',
      systemPrompt: `You are a QA agent. Run tests, check for errors, verify code quality.
1. Run \`npm test\` (Bash tool)
2. Check for TypeScript errors
3. Report: PASS or FAIL with specifics
Be concise. Facts only.`,
      sessionId: '',
    },
    policy: {
      $type: 'ai.policy',
      allow: ['Bash:npm *', 'Bash:ls *', 'Bash:cat *', 'Bash:git status*', 'Bash:git diff*', 'Bash:git log*'],
      deny: [],
      escalate: [],
    },
  })
  await store.set({ $path: '/agents/qa/tasks', $type: 'dir' })

  // Dev agent — writes code, builds features
  await store.set({
    $path: '/agents/dev', $type: 'ai.agent',
    role: 'dev', status: 'idle', currentTask: '', taskRef: '',
    lastRunAt: 0, totalTokens: 0,
    config: {
      $type: 'metatron.config',
      model: 'claude-sonnet-4-6',
      systemPrompt: `You are a dev agent. You build features, fix bugs, write code.
Use MCP tools to inspect the tree. Use Bash for npm/git.
Follow the approved plan. Be concise.`,
      sessionId: '',
    },
    policy: {
      $type: 'ai.policy',
      allow: [
        'Bash:npm *', 'Bash:npx *', 'Bash:tsx *',
        'Bash:ls *', 'Bash:cat *', 'Bash:grep *', 'Bash:rg *',
        'Bash:git status*', 'Bash:git diff*', 'Bash:git log*', 'Bash:git show*',
        'Bash:pwd*', 'Bash:mkdir *', 'Bash:touch *',
      ],
      deny: [],
      escalate: [],
    },
  })
  await store.set({ $path: '/agents/dev/tasks', $type: 'dir' })

  // Board for tasks
  await store.set({ $path: '/board', $type: 'board.kanban' })
  await store.set({ $path: '/board/backlog', $type: 'board.column', title: 'Backlog', order: 0 })
  await store.set({ $path: '/board/data', $type: 'dir' })

  // Autostart — orchestrator starts on server boot
  await store.set({ $path: '/sys/autostart/agents', $type: 'ref', $ref: '/agents' })

  // Sample task to get started
  await store.set({
    $path: '/board/data/hello-world', $type: 'board.task',
    title: 'Hello World — test the agent system',
    description: 'Run npm test and report results. This is a test task to verify the agent system works.',
    status: 'todo',
    assignee: 'qa',
    priority: 'normal',
    createdAt: Date.now(),
  })
}
