{
  "name": "@treenx/fuse",
  "version": "1.0.1",
  "type": "module",
  "description": "Mount Treenix tree as a FUSE filesystem",
  "imports": {
    "#*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "bin": {
    "treenix-mount": "./src/cli.ts"
  },
  "optionalDependencies": {
    "fuse-native": "^2.2.6",
    "koffi": "^2.15.1"
  },
  "peerDependencies": {
    "@treenx/core": "^3.0.0"
  }
}
